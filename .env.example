# Frontend API base URL
# Local development: http://localhost:8000
# GitHub Pages production: use your public backend URL (for example https://your-backend.example.com)
VITE_API_URL=http://localhost:8000

# AI gateway key (note: VITE_ variables are bundled into frontend output)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=smartpayroll

# Backend AI settings
AI_API_URL=https://generativelanguage.googleapis.com/v1/models
AI_MODEL=gemini-2.0-flash
